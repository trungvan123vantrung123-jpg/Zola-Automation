# ============================================================
# Supabase
# Lấy trong Supabase Dashboard -> Settings -> API
# ============================================================

# Dùng ở CẢ client và server, chỉ đọc (anon key) -> AN TOÀN để lộ ra browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# CHỈ dùng ở server (API routes), KHÔNG BAO GIỜ để lộ ra frontend/browser
# Key này có toàn quyền ghi/xoá, bypass RLS
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# n8n
# ============================================================

# URL webhook n8n dùng để nhận request gửi tin nhắn
N8N_SEND_MESSAGE_WEBHOOK_URL=https://your-n8n-domain.com/webhook/send-message

# (Tuỳ chọn nhưng khuyến nghị BẮT BUỘC) Secret để xác thực request giữa
# Next.js <-> n8n, đặt cùng giá trị trong node Webhook (Header Auth) của n8n.
# Dùng cho CẢ 2 chiều: n8n gọi vào /api/job-callback, và web gọi ra webhook n8n.
N8N_WEBHOOK_SECRET=doi-chuoi-nay-thanh-random-string-cua-ban

# ============================================================
# Admin
# ============================================================

# Secret để truy cập trang /admin (duyệt tài khoản, set quota).
# Đây là giải pháp tạm thời cho giai đoạn thủ công, không phải hệ thống
# phân quyền đầy đủ — xem docs/nang-cap-tu-dong-active.md để biết cách
# nâng cấp lên role-based admin sau này.
ADMIN_SECRET=doi-chuoi-nay-thanh-mot-secret-that-manh-va-dai
